# ============================================
# BACKEND - Cau hinh moi truong (Environment)
# ============================================
# Sao chep file nay thanh .env va dien thong tin thuc te:
#   cp .env.example .env
# ============================================

# --- Supabase ---
# URL cua project Supabase (lay tu Settings > API trong Supabase Dashboard)
SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public key cua Supabase (KHONG dung service_role key o day)
SUPABASE_KEY=your_supabase_anon_key_here

# --- Server ---
# Cong chay Express server (mac dinh: 5000)
PORT=5000
